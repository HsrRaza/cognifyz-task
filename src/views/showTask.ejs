<%- include('layouts/main', { body: `
<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8 bg-slate-950">
  <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
    <i class="fa-solid fa-square-check text-emerald-500 text-5xl mb-4 animate-bounce"></i>
    <h2 class="text-3xl font-extrabold tracking-tight text-white">Task Created Directly</h2>
    <p class="mt-2 text-sm text-slate-400">
      This page demonstrates the direct EJS POST flow from Task 1 & 2.
    </p>
  </div>

  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="glass p-8 rounded-2xl <%= task.error ? 'glow-red' : 'glow-green' %> animate-fade-in space-y-6">
      
      <% if (task.error) { %>
        <div class="rounded-md bg-red-900/50 p-4 border border-red-500/30">
          <div class="flex">
            <div class="flex-shrink-0">
              <i class="fa-solid fa-circle-exclamation text-red-400"></i>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-semibold text-red-200">Validation Error</h3>
              <p class="text-xs text-red-300 mt-1"><%= task.error %></p>
            </div>
          </div>
        </div>
      <% } %>

      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider">Task Title</label>
        <div class="mt-1.5 text-lg font-bold text-white"><%= task.title %></div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider">Priority</label>
        <div class="mt-1.5 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium 
          <%= task.priority === 'High' ? 'bg-red-500/10 text-red-400 ring-1 ring-inset ring-red-500/20' : 
              task.priority === 'Medium' ? 'bg-amber-500/10 text-amber-400 ring-1 ring-inset ring-amber-500/20' : 
              'bg-blue-500/10 text-blue-400 ring-1 ring-inset ring-blue-500/20' %>">
          <%= task.priority %>
        </div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider">Description</label>
        <div class="mt-2 text-sm text-slate-300 bg-slate-900/60 p-4 rounded-lg border border-slate-800 leading-relaxed font-mono whitespace-pre-wrap"><%= task.description %></div>
      </div>

      <div class="pt-4 flex gap-4">
        <a href="/tasks" 
           class="flex-1 text-center justify-center rounded-lg bg-indigo-600 px-3 py-2.5 text-sm font-semibold leading-6 text-white shadow-sm hover:bg-indigo-500 transition">
          <i class="fa-solid fa-house mr-1"></i> Go to Dashboard
        </a>
      </div>
      
    </div>
  </div>
</div>
` }) %>
