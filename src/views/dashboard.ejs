<%- include('partials/header') %>

<div class="h-full">
  <!-- Sidebar for Desktop -->
  <%- include('partials/sidebar') %>

  <!-- Main Content Wrapper -->
  <div class="lg:pl-72 flex flex-col min-h-full">
    <!-- Navbar -->
    <%- include('partials/navbar') %>

    <!-- Content Area -->
    <main class="flex-1 py-8 px-4 sm:px-6 lg:px-8">
      
      <!-- Top Greetings & Summary Bar -->
      <div class="md:flex md:items-center md:justify-between mb-8">
        <div class="min-w-0 flex-1">
          <h1 class="text-2xl font-bold leading-7 text-white sm:truncate sm:text-3xl tracking-tight">
            Workspace Dashboard
          </h1>
          <p class="mt-1 text-sm text-slate-400">
            Monitor deadlines, run AI analysis, and manage collaboration.
          </p>
        </div>
        
        <!-- Add Task trigger button -->
        <div class="mt-4 flex md:ml-4 md:mt-0 gap-x-3">
          <button onclick="toggleTaskModal(true)" 
                  class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition">
            <i class="fa-solid fa-plus mr-1.5"></i> New Task
          </button>
        </div>
      </div>

      <!-- Quick filters & Search bar -->
      <div class="glass p-4 rounded-xl mb-6 flex flex-col md:flex-row gap-4 items-center justify-between">
        <div class="w-full md:w-96 relative">
          <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-500">
            <i class="fa-solid fa-magnifying-glass"></i>
          </span>
          <input type="text" id="search-input" onkeyup="filterTasks()"
                 class="block w-full rounded-lg border-0 bg-slate-950 py-2 pl-10 pr-3 text-white ring-1 ring-inset ring-slate-800 placeholder:text-slate-500 focus:ring-2 focus:ring-indigo-500 sm:text-sm sm:leading-6"
                 placeholder="Instant search by title or description...">
        </div>

        <div class="w-full md:w-auto flex flex-wrap gap-3 items-center justify-end">
          <!-- Priority Filter -->
          <select id="filter-priority" onchange="filterTasks()"
                  class="rounded-lg border-0 bg-slate-950 py-2 pl-3 pr-8 text-sm text-slate-300 ring-1 ring-inset ring-slate-800 focus:ring-2 focus:ring-indigo-500">
            <option value="ALL">All Priorities</option>
            <option value="High">High Priority</option>
            <option value="Medium">Medium Priority</option>
            <option value="Low">Low Priority</option>
          </select>

          <!-- Status Filter -->
          <select id="filter-status" onchange="filterTasks()"
                  class="rounded-lg border-0 bg-slate-950 py-2 pl-3 pr-8 text-sm text-slate-300 ring-1 ring-inset ring-slate-800 focus:ring-2 focus:ring-indigo-500">
            <option value="ALL">All Statuses</option>
            <option value="PENDING">Pending Only</option>
            <option value="COMPLETED">Completed Only</option>
          </select>

          <button onclick="resetFilters()" 
                  class="text-xs text-slate-400 hover:text-white underline transition">
            Reset Filters
          </button>
        </div>
      </div>

      <!-- Main Tasks Grid/Content -->
      <div id="tasks-loading-skeleton" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 animate-pulse">
        <div class="h-44 bg-slate-900/60 rounded-2xl border border-slate-800"></div>
        <div class="h-44 bg-slate-900/60 rounded-2xl border border-slate-800"></div>
        <div class="h-44 bg-slate-900/60 rounded-2xl border border-slate-800"></div>
      </div>

      <!-- Actual Tasks Container -->
      <div id="tasks-container" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 hidden">
        <!-- Injected via Javascript fetch -->
      </div>

      <!-- No Tasks Placeholder -->
      <div id="no-tasks-placeholder" class="hidden text-center py-20 bg-slate-900/20 border border-dashed border-slate-850 rounded-2xl">
        <i class="fa-solid fa-list-check text-slate-600 text-6xl mb-4"></i>
        <h3 class="text-lg font-semibold text-white">No tasks found</h3>
        <p class="text-slate-400 text-sm mt-1 max-w-sm mx-auto">
          Start by clicking the "New Task" button to add a task to your dashboard list.
        </p>
      </div>

    </main>
  </div>
</div>

<!-- ========================================== -->
<!-- TASK CREATION / EDIT MODAL -->
<!-- ========================================== -->
<div id="task-modal" class="fixed inset-0 z-50 overflow-y-auto hidden" role="dialog" aria-modal="true">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm transition-opacity"></div>

  <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
    <div class="relative transform overflow-hidden rounded-2xl bg-slate-900 border border-slate-800 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg glow-brand">
      
      <!-- Modal Header -->
      <div class="bg-slate-900/50 px-6 py-4 border-b border-slate-800 flex justify-between items-center">
        <h3 class="text-lg font-bold text-white flex items-center gap-x-2">
          <i class="fa-solid fa-circle-plus text-indigo-500"></i>
          <span id="modal-title">Create Workspace Task</span>
        </h3>
        <button onclick="toggleTaskModal(false)" class="text-slate-400 hover:text-white transition">
          <i class="fa-solid fa-xmark text-lg"></i>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="px-6 py-6 space-y-4">
        <!-- Error alert -->
        <div id="modal-error-banner" class="hidden rounded-lg bg-red-900/40 border border-red-500/30 p-3 text-xs text-red-300">
          <!-- Populated by JS -->
        </div>

        <form id="task-form">
          <!-- Hidden ID for Editing -->
          <input type="hidden" id="task-id">

          <!-- Title Input -->
          <div>
            <div class="flex justify-between items-center">
              <label for="task-title" class="block text-sm font-semibold text-slate-300">Task Name</label>
              <span id="title-char-counter" class="text-xxs text-slate-500 font-mono">0 / 80 chars</span>
            </div>
            <input type="text" id="task-title" required maxlength="80"
                   oninput="updateCharCounter('task-title', 'title-char-counter', 80)"
                   class="mt-1.5 block w-full rounded-lg border-0 bg-slate-950 py-2 px-3 text-white ring-1 ring-inset ring-slate-800 placeholder:text-slate-600 focus:ring-2 focus:ring-indigo-500 sm:text-sm"
                   placeholder="e.g. Implement User Authentication">
            <p id="task-title-error" class="text-xxs text-red-400 mt-1 hidden"></p>
          </div>

          <!-- Description Input -->
          <div class="mt-4">
            <div class="flex justify-between items-center">
              <label for="task-desc" class="block text-sm font-semibold text-slate-300">Description</label>
              <div class="flex items-center gap-x-2">
                <button type="button" onclick="triggerAIDescription()" id="ai-desc-btn"
                        class="text-xxs bg-indigo-500/10 text-indigo-400 px-2 py-0.5 rounded-full border border-indigo-500/20 hover:bg-indigo-500/20 transition flex items-center gap-1">
                  <i class="fa-solid fa-wand-magic-sparkles animate-pulse"></i> AI Auto-Fill
                </button>
                <span id="desc-char-counter" class="text-xxs text-slate-500 font-mono">0 / 500 chars</span>
              </div>
            </div>
            <textarea id="task-desc" required rows="4" maxlength="500"
                      oninput="updateCharCounter('task-desc', 'desc-char-counter', 500)"
                      class="mt-1.5 block w-full rounded-lg border-0 bg-slate-950 py-2 px-3 text-white ring-1 ring-inset ring-slate-800 placeholder:text-slate-655 focus:ring-2 focus:ring-indigo-500 sm:text-sm font-sans"
                      placeholder="Enter task scope (minimum 10 characters)..."></textarea>
            <p id="task-desc-error" class="text-xxs text-red-400 mt-1 hidden"></p>
          </div>

          <!-- Priority Selector & AI Predictor -->
          <div class="grid grid-cols-2 gap-4 mt-4">
            <div>
              <div class="flex items-center justify-between">
                <label for="task-priority" class="block text-sm font-semibold text-slate-300">Priority</label>
                <button type="button" onclick="triggerAIPriority()" id="ai-priority-btn"
                        class="text-[10px] text-indigo-400 hover:text-indigo-300 transition flex items-center gap-0.5">
                  <i class="fa-solid fa-brain"></i> Suggest
                </button>
              </div>
              <select id="task-priority"
                      class="mt-1.5 block w-full rounded-lg border-0 bg-slate-950 py-2 px-3 text-white ring-1 ring-inset ring-slate-800 focus:ring-2 focus:ring-indigo-500 sm:text-sm">
                <option value="Low">Low</option>
                <option value="Medium" selected>Medium</option>
                <option value="High">High</option>
              </select>
            </div>

            <!-- Due Date -->
            <div>
              <label for="task-duedate" class="block text-sm font-semibold text-slate-300">Due Date</label>
              <input type="date" id="task-duedate"
                     class="mt-1.5 block w-full rounded-lg border-0 bg-slate-950 py-2 px-3 text-white ring-1 ring-inset ring-slate-800 focus:ring-2 focus:ring-indigo-500 sm:text-sm">
            </div>
          </div>
        </form>
      </div>

      <!-- Modal Footer -->
      <div class="bg-slate-950/40 px-6 py-4 border-t border-slate-800 flex justify-between items-center">
        <!-- Direct EJS Submission Trigger for Task 1/2 Check -->
        <button type="button" onclick="triggerDirectFormPost()"
                class="text-xxs text-slate-500 hover:text-slate-300 underline font-mono transition">
          Direct EJS Form POST
        </button>

        <div class="flex gap-x-3">
          <button type="button" onclick="toggleTaskModal(false)"
                  class="rounded-lg bg-slate-900 border border-slate-800 px-4 py-2 text-sm font-semibold text-slate-400 hover:bg-slate-800 hover:text-white transition">
            Cancel
          </button>
          <button type="button" onclick="saveTask(event)" id="modal-submit-btn"
                  class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 shadow-md transition">
            Save Task
          </button>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Scripts -->
<script src="/js/dashboard.js"></script>

<%- include('partials/footer') %>
