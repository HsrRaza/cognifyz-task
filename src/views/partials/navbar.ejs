<header class="glass sticky top-0 z-40 flex h-16 shrink-0 items-center gap-x-4 border-b border-slate-800 px-4 shadow-sm sm:gap-x-6 sm:px-6 lg:px-8">
  <div class="flex flex-1 items-center gap-x-4 lg:gap-x-6">
    <!-- Brand / Title -->
    <div class="flex items-center gap-x-2">
      <i class="fa-solid fa-square-kanban text-indigo-500 text-2xl animate-pulse-slow"></i>
      <span class="text-xl font-bold tracking-tight text-white hidden sm:inline-block">CogniTask <span class="text-indigo-400 font-medium text-sm">SaaS</span></span>
    </div>
    
    <div class="h-6 w-px bg-slate-800 lg:hidden"></div>

    <div class="flex flex-1 justify-end items-center gap-x-4 lg:gap-x-6">
      <!-- AI Status Pill -->
      <span class="inline-flex items-center gap-x-1.5 rounded-full bg-indigo-500/10 px-3 py-1.5 text-xs font-semibold text-indigo-400 ring-1 ring-inset ring-indigo-500/20">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-indigo-500"></span>
        </span>
        AI Advisor Online
      </span>

      <!-- Divider -->
      <div class="hidden md:block h-6 w-px bg-slate-800"></div>

      <!-- User Welcome & Menu -->
      <div class="flex items-center gap-x-4">
        <% if (user) { %>
          <div class="text-right hidden sm:block">
            <p class="text-sm font-medium text-slate-100"><%= user.username %></p>
            <p class="text-xs text-slate-400 font-mono"><%= user.email %></p>
          </div>
          <!-- Avatar Icon -->
          <div class="h-9 w-9 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-indigo-400 font-semibold shadow-inner">
            <%= user.username.substring(0, 2).toUpperCase() %>
          </div>
          <!-- Logout Button -->
          <a href="/auth/logout" class="rounded-lg bg-slate-900 border border-slate-800 px-3 py-1.5 text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800 hover:border-slate-700 transition duration-150">
            <i class="fa-solid fa-right-from-bracket mr-1"></i> Logout
          </a>
        <% } else { %>
          <a href="/auth/login" class="text-sm font-medium text-slate-300 hover:text-white transition">Sign In</a>
          <a href="/auth/register" class="rounded-md bg-indigo-600 px-3.5 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition">Get Started</a>
        <% } %>
      </div>
    </div>
  </div>
</header>
