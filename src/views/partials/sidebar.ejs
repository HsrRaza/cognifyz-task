<aside class="hidden lg:flex lg:w-72 lg:flex-col lg:fixed lg:inset-y-0 lg:z-30 bg-slate-900 border-r border-slate-800 px-6 pb-4 pt-16">
  <div class="flex flex-1 flex-col gap-y-7 overflow-y-auto mt-6">
    <!-- Navigation section -->
    <nav class="flex flex-col flex-1">
      <ul role="list" class="flex flex-col flex-1 gap-y-7">
        <li>
          <div class="text-xs font-semibold leading-6 text-slate-400 uppercase tracking-wider">Navigation</div>
          <ul role="list" class="-mx-2 mt-2 space-y-1">
            <li>
              <a href="/tasks" class="bg-slate-800 text-white group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold">
                <i class="fa-solid fa-list-check text-indigo-400 text-lg flex items-center justify-center w-6"></i>
                My Workspace
              </a>
            </li>
            <li>
              <button onclick="triggerAISummary()" class="w-full text-left text-slate-300 hover:text-white hover:bg-slate-800 group flex gap-x-3 rounded-md p-2 text-sm leading-6 font-semibold transition">
                <i class="fa-solid fa-wand-magic-sparkles text-indigo-400 text-lg flex items-center justify-center w-6 animate-pulse"></i>
                AI Task Summary
              </button>
            </li>
          </ul>
        </li>

        <!-- Statistics section -->
        <li>
          <div class="text-xs font-semibold leading-6 text-slate-400 uppercase tracking-wider">Live Workspace Stats</div>
          <div class="mt-4 grid grid-cols-2 gap-4">
            <!-- Total Tasks -->
            <div class="bg-slate-950 p-3 rounded-lg border border-slate-800 text-center">
              <span id="stat-total" class="block text-2xl font-bold text-white font-mono">-</span>
              <span class="text-xxs text-slate-500 uppercase tracking-wider">Total</span>
            </div>
            <!-- Completed -->
            <div class="bg-slate-950 p-3 rounded-lg border border-slate-800 text-center">
              <span id="stat-completed" class="block text-2xl font-bold text-emerald-400 font-mono">-</span>
              <span class="text-xxs text-slate-500 uppercase tracking-wider">Done</span>
            </div>
            <!-- Pending -->
            <div class="bg-slate-950 p-3 rounded-lg border border-slate-800 text-center">
              <span id="stat-pending" class="block text-2xl font-bold text-amber-400 font-mono">-</span>
              <span class="text-xxs text-slate-500 uppercase tracking-wider">Pending</span>
            </div>
            <!-- High Priority -->
            <div class="bg-slate-950 p-3 rounded-lg border border-slate-800 text-center">
              <span id="stat-high" class="block text-2xl font-bold text-rose-500 font-mono">-</span>
              <span class="text-xxs text-slate-500 uppercase tracking-wider">Urgent</span>
            </div>
          </div>

          <!-- Progress bar -->
          <div class="mt-4 bg-slate-950 p-3 rounded-lg border border-slate-800">
            <div class="flex justify-between items-center text-xs text-slate-400 mb-1">
              <span>Completion Rate</span>
              <span id="stat-completion-pct" class="font-bold text-white">0%</span>
            </div>
            <div class="w-full bg-slate-800 rounded-full h-1.5 overflow-hidden">
              <div id="stat-progress-bar" class="bg-indigo-500 h-1.5 rounded-full transition-all duration-500" style="width: 0%"></div>
            </div>
          </div>
        </li>

        <!-- AI Assistant summary panel -->
        <li class="mt-auto">
          <div class="bg-slate-950 border border-indigo-500/20 p-4 rounded-xl relative overflow-hidden group">
            <div class="absolute -top-10 -right-10 w-24 h-24 bg-indigo-500/10 rounded-full blur-xl group-hover:bg-indigo-500/20 transition-all duration-300"></div>
            <div class="flex items-center gap-x-2 text-xs font-semibold text-indigo-400 uppercase tracking-wider mb-2">
              <i class="fa-solid fa-brain"></i>
              AI Assistant
            </div>
            <p id="ai-summary-text" class="text-xs text-slate-400 leading-relaxed italic">
              "Click 'AI Task Summary' above to generate an intelligent analysis of your current tasks and workload recommendations."
            </p>
          </div>
        </li>
      </ul>
    </nav>
  </div>
</aside>
